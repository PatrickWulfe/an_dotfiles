      "args": [
        "-y",
        "@configcat/mcp-server"
      ]
    },
    "Figma-desktop": {
      "url": "http://127.0.0.1:3845/mcp",
      "env": {},
      "args": []
    },
    "coda": {
      "command": "npx",
      "env": {
        "API_KEY": "${env:CODA_API_KEY}"
      },
      "args": [
        "-y",
        "coda-mcp@latest"
