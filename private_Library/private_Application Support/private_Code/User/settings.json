    "editor.defaultFormatter": "mikeburgh.xml-format"
  },
  // ============================================================================
  // THEME CUSTOMIZATIONS
  // ============================================================================
  // --- Color Customizations ---
  "workbench.colorCustomizations": {
    "window.background": "#FFFFFF",
    "[Cold Horizon]": {
      "dart.closingLabels": "#6C6F9377",
      "editorBracketHighlight.foreground1": "#FAB28E",
      "editorBracketHighlight.foreground2": "#F43E5C",
      "editorBracketHighlight.foreground3": "#09F7A0"
    },
    "[Horizon*]": {
      "dart.closingLabels": "#696F9C77",
      "editorBracketHighlight.foreground1": "#B877DB",
      "editorBracketHighlight.foreground2": "#21BFC2",
      "editorBracketHighlight.foreground3": "#09F7A0",
      "editorCursor.foreground": "#59E3E3"
    },
    "[Tokyo Night*]": {
      "dart.closingLabels": "#747CA1AA",
      "editorIndentGuide.background1": "#565f8948",
      "statusBar.background": "#1a1b26",
      "statusBar.debuggingBackground": "#1a1b26",
      "statusBar.noFolderBackground": "#1a1b26"
    }
  },
  // --- Semantic Token Color Customizations ---
  "editor.semanticTokenColorCustomizations": {
    "[Bearded Theme*]": {
      "enabled": true,
      "rules": {
        "*.declaration": {
          "bold": true
        },
        "parameter": {
          "fontStyle": "italic"
        }
      }
    },
    "[Cold Horizon*]": {
      "enabled": true,
      "rules": {
        "*.declaration": {
          "bold": true
        },
        "enumMember": "#B877DB",
        "keyword": {
          "bold": true,
          "italic": true
        },
        "keyword.control": {
          "bold": false,
          "italic": false
        },
        "parameter": "#B877DB",
        "variable": "#B877DB"
      }
    },
    "[Horizon*]": {
      "enabled": true,
      "rules": {
        "*.declaration": {
          "bold": true
        }
      }
    },
    "[Moonlight*]": {
      "enabled": true,
      "rules": {
        "*.declaration": {
          "bold": true
        },
        "parameter": {
          "fontStyle": "italic"
        }
      }
    },
    "[Night Owl]": {
      "enabled": true,
      "rules": {
        "*.declaration": {
          "bold": true
        },
        "class": "#fccb8b",
        "parameter": {
          "fontStyle": "italic"
        }
      }
    },
    "[Outrun*]": {
      "enabled": true
    },
    "[Radical]": {
      "enabled": true,
      "rules": {
        "parameter": {
          "fontStyle": "italic"
        }
      }
    },
    "[Tailwind*]": {
      "enabled": true,
      "rules": {
        "parameter": {
          "fontStyle": "italic"
        }
      }
    },
    "[Tokyo Night*]": {
      "enabled": true,
      "rules": {
        "parameter": {
          "fontStyle": "italic"
        },
        "variable": "#7dcfff"
      }
    }
  },
  // --- Token Color Customizations (TextMate Rules) ---
  "editor.tokenColorCustomizations": {
    "[Bearded Theme Arc*]": {
      "textMateRules": [
        {
          "scope": [
            "keyword.operator",
            "keyword.operator.assignment",
            "keyword.operator.comparison",
            "keyword.operator.logical"
          ],
          "settings": {
            "foreground": "#FFFFFF"
          }
        }
      ]
    },
    "[Cold Horizon]": {
      "textMateRules": [
        {
          "scope": "comment",
          "settings": {
            "foreground": "#6C6F93"
          }
        },
        {
