      "command": "npx",
      "env": {
        "AZURE_DEVOPS_PAT": "${env:AZURE_DEVOPS_PAT}"
      },
      "args": [
        "-y",
        "@azure-devops/mcp",
        "${input:ado_org}"
      ]
    },
    "ConfigCat": {
      "command": "npx",
      "env": {
        "CONFIGCAT_API_USER": "${env:CONFIGCAT_API_USER}",
        "CONFIGCAT_API_PASS": "${env:CONFIGCAT_API_PASS}"
